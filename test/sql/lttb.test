query I
SELECT list_transform(lttb(epoch(x)::DOUBLE, y, 5), lambda p: format('({}, {:.6f})', strftime(to_timestamp(p.x), '%Y-%m-%d'), p.y)) FROM lttb_datetime_input;
----
['(2023-01-14, 35.965280)', '(2023-03-15, 98.777095)', '(2023-06-05, 8.107958)', '(2023-12-18, 12.832033)', '(2023-12-31, 98.523759)']

# Ported from ClickHouse PR #57003 bucket-size regression inside 02842_largestTriangleThreeBuckets_aggregate_function.sql.
query III
WITH sampled AS (
    SELECT row_number() OVER () AS rn, unnest(lttb(i::DOUBLE + 1, (i + 1) % 1000, 1000)) AS point
    FROM range(9999) AS t(i)
), points AS (
    SELECT rn, point.x::BIGINT AS point_x, point.y::BIGINT AS point_y FROM sampled
)
SELECT format('({}, {})', point_x, point_y), point_x, point_x - lag(point_x) OVER (ORDER BY rn)
FROM points
ORDER BY rn
LIMIT 10 OFFSET 990;
----
(9908, 908)	9908	10
(9918, 918)	9918	10
(9928, 928)	9928	10
(9938, 938)	9938	10
(9948, 948)	9948	10
(9958, 958)	9958	10
(9968, 968)	9968	10
(9978, 978)	9978	10
(9988, 988)	9988	10
(9999, 999)	9999	11

query II rowsort
SELECT g, list_transform(lttb(x, y, 2), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT))
FROM (VALUES (1, 2.0, 20.0), (1, 1.0, 10.0), (2, 4.0, 40.0), (2, 3.0, 30.0)) AS t(g, x, y)
GROUP BY g;
----
1	['(1, 10)', '(2, 20)']
2	['(3, 30)', '(4, 40)']

statement error
SELECT lttb(x, y, CASE WHEN x = 1 THEN 2 ELSE 3 END::BIGINT) FROM lttb_input;
----
lttb bucket count must be constant within each aggregate group

# Duplicate x stability: stable_sort preserves input order for equal x values.
statement ok
CREATE TABLE lttb_dup_x (x DOUBLE, y DOUBLE);

statement ok
INSERT INTO lttb_dup_x VALUES (2.0, 40.0), (1.0, 10.0), (1.0, 20.0), (2.0, 30.0);

query I
SELECT list_transform(lttb(x, y, 4), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT)) FROM lttb_dup_x;
----
['(1, 10)', '(1, 20)', '(2, 40)', '(2, 30)']

statement ok
DROP TABLE lttb_dup_x;

# All-invalid input tests.
query I
SELECT list_transform(lttb('NaN'::DOUBLE, 1.0, 1), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT));
----
[]

query I
SELECT list_transform(lttb(NULL, 1.0, 1), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT));
----
[]

query I
SELECT list_transform(lttb(1.0, NULL, 1), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT));
----
[]

query I
SELECT list_transform(lttb(NULL::DOUBLE, NULL::DOUBLE, 1), lambda p: format('({}, {})', p.x::BIGINT, p.y::BIGINT));
----
[]

statement error
SELECT lttb(1.0, 1.0, -1);
----
lttb bucket count must be non-negative
